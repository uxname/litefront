# Application Configurations
PORT=3000
VITE_BASE_URL=http://localhost:3000
# Point this at the liteend backend GraphQL endpoint.
VITE_GRAPHQL_API_URL=http://localhost:4000/graphql

# OIDC Configuration
# NOTE: the authority + client_id below are INTENTIONALLY hardcoded to a shared dev Logto
# tenant so the boilerplate authenticates out of the box. These are PUBLIC OIDC identifiers,
# not secrets: a SPA uses PKCE (no client_secret) and the client_id is already exposed in the
# browser's auth request. Swap them for your own tenant in a real project. Real secrets live
# in `.env` (gitignored), never here.
VITE_OIDC_AUTHORITY=https://auth.uxna.me/oidc
VITE_OIDC_CLIENT_ID=gdwtltuj70l6wo3k9rui1
VITE_OIDC_REDIRECT_URI=http://localhost:3000/callback
VITE_OIDC_SCOPE='openid profile offline_access'
# Logto API resource indicator — access_token is requested for this resource so its
# `aud` matches the backend's OIDC_AUDIENCE. Register the resource in Logto Console.
VITE_OIDC_API_RESOURCE=http://localhost:4000

# Sentry Configuration
VITE_SENTRY_DSN=
VITE_SENTRY_ORG=
VITE_SENTRY_PROJECT=
VITE_SENTRY_AUTH_TOKEN=

# Mock / Dev
VITE_MOCK_AUTH=false
VITE_APP_VERSION=development
